@model IEnumerable<QuanLyCanTeenHutech.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    var isEnglish = System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("en");
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <h3 class="fw-bold text-dark mb-4"><i class="fa-solid fa-cart-shopping text-secondary me-2"></i> Giỏ hàng của tôi</h3>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm text-center py-5 rounded-3 bg-white">
                <div class="py-4">
                    <i class="fa-solid fa-basket-shopping text-muted display-4 mb-3"></i>
                    <h5 class="text-muted">Giỏ hàng của bạn đang trống</h5>
                    <p class="text-muted fs-14">Hãy chọn món ngon tại căng tin và thêm vào giỏ hàng nhé.</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4 mt-2">Xem thực đơn</a>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <!-- Cart Items List (Left Side) -->
                <div class="col-lg-8 mb-4">
                    <div class="card border-0 shadow-sm rounded-3 overflow-hidden bg-white p-4">
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr class="table-light">
                                        <th style="width: 50%;">Sản phẩm / Món ăn</th>
                                        <th class="text-center" style="width: 25%;">Số lượng</th>
                                        <th class="text-end" style="width: 25%;">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var rowId = "cart-row-" + item.ProductId;
                                        var subtotalId = "subtotal-" + item.ProductId;
                                        var itemName = (isEnglish && !string.IsNullOrEmpty(item.ProductNameEn)) ? item.ProductNameEn : item.ProductName;
                                        <tr id="@rowId">
                                            <td class="py-3">
                                                <div class="d-flex align-items-center gap-3">
                                                    <!-- Food image thumbnail -->
                                                    <div class="rounded-3 overflow-hidden bg-light border" style="width: 60px; height: 60px;">
                                                        <img src="@item.ImageUrl" class="object-fit-cover w-100 h-100" alt="@itemName" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'60\' height=\'60\' viewBox=\'0 0 60 60\'><rect width=\'60\' height=\'60\' fill=\'%23e2e8f0\'/><text x=\'50%\' y=\'50%\' dominant-baseline=\'middle\' text-anchor=\'middle\' font-size=\'8\' fill=\'%2364748b\'>Food</text></svg>'" />
                                                    </div>
                                                    <div>
                                                        <h6 class="fw-bold text-dark mb-1">@itemName</h6>
                                                        <span class="text-muted fs-13">Đơn giá: @item.Price.ToString("#,##0") đ</span>
                                                        
                                                        <!-- Remove form -->
                                                        <form asp-action="RemoveFromCart" method="post" class="mt-1">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                                            <button type="submit" class="btn btn-link text-danger text-decoration-none p-0 fs-12">
                                                                <i class="fa-solid fa-trash-can me-1"></i> Xóa
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </td>
                                            
                                            <!-- Quantity Picker -->
                                            <td class="text-center py-3">
                                                <div class="d-inline-flex align-items-center border rounded-pill bg-light p-1" style="width: 110px;">
                                                    <button type="button" class="btn btn-link text-decoration-none py-0 px-2 fw-bold text-secondary fs-14" onclick="updateQty(@item.ProductId, -1)">-</button>
                                                    <input type="number" id="input-qty-@item.ProductId" value="@item.Quantity" min="1" max="100" class="form-control border-0 bg-transparent text-center p-0 font-weight-600 fs-14" style="box-shadow:none;" onchange="sendUpdateQty(@item.ProductId, this.value)" />
                                                    <button type="button" class="btn btn-link text-decoration-none py-0 px-2 fw-bold text-secondary fs-14" onclick="updateQty(@item.ProductId, 1)">+</button>
                                                </div>
                                            </td>
                                            
                                            <!-- Subtotal -->
                                            <td class="text-end py-3">
                                                <strong class="text-dark fs-15" id="@subtotalId">@item.Subtotal.ToString("#,##0") đ</strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Order Summary (Right Side) -->
                <div class="col-lg-4 mb-4">
                    <div class="card border-0 shadow-sm rounded-3 overflow-hidden bg-white p-4">
                        <h5 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="fa-solid fa-receipt me-2 text-secondary"></i> Tổng kết đơn hàng</h5>
                        
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted">Tổng số lượng sản phẩm:</span>
                            <span class="fw-bold" id="summary-total-qty">@Model.Sum(c => c.Quantity)</span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mb-4 border-top pt-3">
                            <span class="fw-bold text-dark">Tổng tiền thanh toán:</span>
                            <span class="fs-20 fw-bold text-primary" id="cart-total-price">@Model.Sum(c => c.Subtotal).ToString("#,##0") đ</span>
                        </div>
                        
                        <div class="d-flex flex-column gap-2 mt-4">
                            <a href="/Cart/Checkout" class="btn btn-primary rounded-pill py-2 fw-bold">
                                <i class="fa-solid fa-circle-check me-2"></i> Tiến hành thanh toán
                            </a>
                            <a href="/" class="btn btn-light border rounded-pill py-2">
                                Tiếp tục chọn món ăn
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
    function updateQty(productId, amount) {
        const input = document.getElementById("input-qty-" + productId);
        let val = parseInt(input.value) || 1;
        val += amount;
        if (val < 1) val = 1;
        input.value = val;
        sendUpdateQty(productId, val);
    }

    function sendUpdateQty(productId, quantity) {
        if (quantity < 1) return;

        fetch('/Cart/UpdateCart?productId=' + productId + '&quantity=' + quantity, {
            method: 'POST'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update subtotal for item row
                document.getElementById("subtotal-" + productId).innerText = data.subtotal;
                // Update cart total price
                document.getElementById("cart-total-price").innerText = data.total;

                // Update summary total quantity
                let totalQty = 0;
                document.querySelectorAll("input[id^='input-qty-']").forEach(inp => {
                    totalQty += parseInt(inp.value) || 0;
                });
                document.getElementById("summary-total-qty").innerText = totalQty;
            } else {
                alert("Không thể cập nhật số lượng.");
            }
        })
        .catch(error => {
            console.error(error);
            alert("Lỗi kết nối tới máy chủ.");
        });
    }
</script>
