@model IEnumerable<QuanLyCanTeenHutech.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <h3 class="fw-bold text-dark mb-4"><i class="fa-solid fa-clock-rotate-left text-secondary me-2"></i> Lịch sử đơn hàng của tôi</h3>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm text-center py-5 rounded-3 bg-white">
                <div class="py-4">
                    <i class="fa-solid fa-receipt text-muted display-4 mb-3"></i>
                    <h5 class="text-muted">Bạn chưa đặt đơn hàng nào</h5>
                    <p class="text-muted fs-14">Hãy chọn món ngon tại căng tin và thưởng thức ngay.</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4 mt-2">Xem thực đơn</a>
                </div>
            </div>
        }
        else
        {
            foreach (var order in Model)
            {
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden bg-white mb-4">
                    <!-- Card Header -->
                    <div class="card-header bg-light border-0 py-3 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <span class="text-muted fs-13">Mã đơn hàng:</span> <strong>#@order.Id</strong>
                            <span class="mx-2 text-muted">|</span>
                            <span class="text-muted fs-13">Ngày đặt:</span> <strong>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</strong>
                        </div>
                        <div>
                            <span class="text-muted fs-13 me-1">Trạng thái:</span>
                            @if (order.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark px-3 py-1 rounded-pill">Chờ xử lý</span>
                            }
                            else if (order.Status == "Confirmed")
                            {
                                <span class="badge bg-info text-white px-3 py-1 rounded-pill">Đã xác nhận</span>
                            }
                            else if (order.Status == "Completed")
                            {
                                <span class="badge bg-success text-white px-3 py-1 rounded-pill">Hoàn thành</span>
                            }
                            else
                            {
                                <span class="badge bg-danger text-white px-3 py-1 rounded-pill">Đã hủy</span>
                            }
                        </div>
                    </div>
                    
                    <!-- Card Body -->
                    <div class="card-body p-4">
                        <div class="row">
                            <div class="col-md-7 border-end-md">
                                <h6 class="fw-bold mb-3"><i class="fa-solid fa-list-check me-2"></i> Chi tiết món ăn</h6>
                                <div class="table-responsive">
                                    <table class="table table-borderless table-sm align-middle fs-14 m-0">
                                        <tbody>
                                            @foreach (var detail in order.OrderDetails)
                                            {
                                                var subtotal = detail.ProductPrice * detail.Quantity;
                                                <tr>
                                                    <td class="ps-0 py-2" style="width: 60%;">
                                                        @detail.ProductName
                                                        @if (detail.ProductId == null)
                                                        {
                                                            <br /><span class="text-danger fs-11"><i class="fa-solid fa-circle-exclamation"></i> Món ăn này hiện đã bị gỡ</span>
                                                        }
                                                    </td>
                                                    <td class="text-muted py-2" style="width: 20%;">x @detail.Quantity</td>
                                                    <td class="text-end fw-bold py-2" style="width: 20%;">@subtotal.ToString("#,##0") đ</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="col-md-5 ps-md-4 mt-3 mt-md-0">
                                <h6 class="fw-bold mb-3"><i class="fa-solid fa-location-dot me-2"></i> Thông tin nhận món</h6>
                                <table class="table table-borderless table-sm fs-14 m-0">
                                    <tr>
                                        <td class="text-muted ps-0 py-1" style="width: 100px;">Họ tên:</td>
                                        <td class="py-1">@order.FullName</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted ps-0 py-1">Số điện thoại:</td>
                                        <td class="py-1">@order.PhoneNumber</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted ps-0 py-1">Bàn nhận:</td>
                                        <td class="py-1"><span class="badge bg-light text-dark border">@order.ShippingAddress</span></td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(order.Notes))
                                    {
                                        <tr>
                                            <td class="text-muted ps-0 py-1">Ghi chú:</td>
                                            <td class="py-1 text-muted">@order.Notes</td>
                                        </tr>
                                    }
                                </table>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Card Footer -->
                    <div class="card-footer bg-white border-top-0 py-3 px-4 d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-dark fs-15">Thành tiền:</span>
                        <span class="fs-18 fw-bold text-primary">@order.TotalAmount.ToString("#,##0") đ</span>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    @@media (min-content-width: 768px) {
        .border-end-md {
            border-right: 1px solid #e2e8f0;
        }
    }
</style>
