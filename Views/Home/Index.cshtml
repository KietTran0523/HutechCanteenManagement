@model IEnumerable<QuanLyCanTeenHutech.Models.Product>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Home"];
    var categories = ViewBag.Categories as IEnumerable<QuanLyCanTeenHutech.Models.Category> ?? new List<QuanLyCanTeenHutech.Models.Category>();
    var selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    var categoryName = ViewBag.CategoryName as string;
    var searchTerm = ViewBag.SearchTerm as string;
    var isEnglish = System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("en");
}

<!-- Hero banner section -->
<section class="canteen-hero text-white mb-5 py-5 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);">
    <div class="container py-4 text-center">
        <h1 class="display-5 fw-bold mb-2"><i class="fa-solid fa-graduation-cap"></i> @Localizer["HeroTitle"]</h1>
        <p class="lead mb-4 opacity-75">@Localizer["HeroSubtitle"]</p>
        
        <!-- Search bar -->
        <div class="row justify-content-center">
            <div class="col-md-6 col-sm-10">
                <form asp-controller="Home" asp-action="Index" method="get" class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden bg-white p-1">
                    <input type="text" name="search" value="@searchTerm" class="form-control border-0 px-4 fs-16" placeholder="@Localizer["SearchPlaceholder"]" style="outline:none; box-shadow:none;" />
                    <button class="btn btn-primary rounded-pill px-4" type="submit">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

<div class="row">
    <!-- Categories List (Left Sidebar) -->
    <div class="col-lg-3 mb-4">
        <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
            <h5 class="fw-bold mb-3 pb-2 border-bottom text-dark"><i class="fa-solid fa-burger text-secondary me-2"></i> @Localizer["MenuCategories"]</h5>
            <div class="d-flex flex-column gap-2">
                <a href="/" class="btn text-start py-2 px-3 rounded-3 fs-14 @(selectedCategoryId == null ? "btn-primary" : "btn-light border-0")">
                    <i class="fa-solid fa-border-all me-2"></i> @Localizer["AllDishes"]
                </a>
                @foreach (var cat in categories)
                {
                    var catName = (isEnglish && !string.IsNullOrEmpty(cat.NameEn)) ? cat.NameEn : cat.Name;
                    <a href="/danh-muc/@cat.Slug" class="btn text-start py-2 px-3 rounded-3 fs-14 @(selectedCategoryId == cat.Id ? "btn-primary" : "btn-light border-0")">
                        <i class="fa-solid fa-angle-right me-2"></i> @catName
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Products Grid (Right Side) -->
    <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold text-dark m-0">
                @if (selectedCategoryId.HasValue)
                {
                    <text>@Html.Raw(string.Format(Localizer["MenuFor"].Value, categoryName))</text>
                }
                else if (!string.IsNullOrEmpty(searchTerm))
                {
                    <text>@Html.Raw(string.Format(Localizer["SearchResultsFor"].Value, searchTerm))</text>
                }
                else
                {
                    <text>@Localizer["TodaySpecials"]</text>
                }
            </h4>
            <span class="text-muted fs-14">@Html.Raw(string.Format(Localizer["FoundDishes"].Value, Model.Count()))</span>
        </div>

        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm text-center py-5 rounded-3 bg-white">
                <div class="py-4">
                    <i class="fa-solid fa-utensils text-muted display-4 mb-3"></i>
                    <h5 class="text-muted">@Localizer["NoDishesFound"]</h5>
                    <p class="text-muted fs-14">@Localizer["PleaseTryAgain"]</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4 mt-2">@Localizer["ViewFullMenu"]</a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    var itemName = (isEnglish && !string.IsNullOrEmpty(item.NameEn)) ? item.NameEn : item.Name;
                    var itemDesc = (isEnglish && !string.IsNullOrEmpty(item.DescriptionEn)) ? item.DescriptionEn : item.Description;
                    var catName = (item.Category != null) ? ((isEnglish && !string.IsNullOrEmpty(item.Category.NameEn)) ? item.Category.NameEn : item.Category.Name) : "";
                    
                    var mainImage = item.ProductGalleries.FirstOrDefault(g => g.MediaType == "image")?.FilePath ?? "/images/default-food.svg";
                    <div class="col-md-6 col-xl-4">
                        <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden product-card bg-white">
                            <!-- Image container -->
                            <div class="position-relative ratio ratio-4x3 bg-light overflow-hidden">
                                <div>
                                    <img src="@mainImage" class="object-fit-cover w-100 h-100 transition-img" alt="@itemName" onerror="this.src='/images/default-food.svg'" />
                                    
                                    @if (item.Category != null)
                                    {
                                        <span class="position-absolute top-3 start-3 badge bg-dark bg-opacity-75 rounded-pill px-3 py-1 fs-11">
                                            @catName
                                        </span>
                                    }
                                </div>
                            </div>
                            
                            <!-- Body -->
                            <div class="card-body p-4 d-flex flex-column">
                                <h5 class="card-title fw-bold text-dark mb-1">
                                    <a href="/mon-an/@item.Slug" class="text-decoration-none text-dark hover-primary">@itemName</a>
                                </h5>
                                <p class="card-text text-muted fs-13 line-clamp-2 flex-grow-1">
                                    @(string.IsNullOrEmpty(itemDesc) ? Localizer["DefaultDescription"].Value : itemDesc)
                                </p>
                                
                                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                    <div class="product-price">
                                        <span class="fs-18 fw-bold text-primary">@item.Price.ToString("#,##0") đ</span>
                                    </div>
                                    
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                            <i class="fa-solid fa-cart-plus me-1"></i> @Localizer["AddToCart"]
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .product-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }
    .transition-img {
        transition: transform 0.3s ease;
    }
    .product-card:hover .transition-img {
        transform: scale(1.05);
    }
    .hover-primary:hover {
        color: #3b82f6 !important;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .top-3 { top: 1rem; }
    .start-3 { left: 1rem; }
</style>
