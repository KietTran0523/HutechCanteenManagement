@using Microsoft.AspNetCore.Mvc.Localization
@using QuanLyCanTeenHutech.Common
@inject IViewLocalizer Localizer
@{
    var cartCount = Context.Session.GetObjectFromJson<List<CartItem>>("CanteenCart")?.Sum(c => c.Quantity) ?? 0;
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["CanteenName"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="sticky-top shadow-sm bg-white">
        <nav class="navbar navbar-expand-lg navbar-light py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                    <i class="fa-solid fa-utensils text-primary fs-22"></i>
                    <span class="fw-bold tracking-wide text-dark">HUTECH <span class="text-primary">Canteen</span></span>
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="fa-solid fa-bars"></i>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-2">
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill fs-15 @(Context.Request.Path == "/" ? "active fw-bold text-primary" : "text-secondary")" href="/">
                                <i class="fa-solid fa-house me-1"></i> @Localizer["Home"]
                            </a>
                        </li>
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 rounded-pill fs-15 @(Context.Request.Path == "/don-hang-cua-toi" ? "active fw-bold text-primary" : "text-secondary")" href="/don-hang-cua-toi">
                                    <i class="fa-solid fa-receipt me-1"></i> @Localizer["Orders"]
                                </a>
                            </li>

                            @if (!User.IsInRole("Admin") && !User.IsInRole("Employee"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-3 rounded-pill fs-15 position-relative @(Context.Request.Path == "/Chat" ? "active fw-bold text-primary" : "text-secondary")" href="/Chat">
                                        <i class="fa-solid fa-comments me-1"></i> Chat
                                        <span id="publicChatDot" class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle d-none"></span>
                                    </a>
                                </li>
                            }
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 rounded-pill fs-15 text-danger fw-500" href="/Admin">
                                    <i class="fa-solid fa-user-shield me-1"></i> @Localizer["AdminPanel"]
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Right Section: Language Switcher, Cart, Login -->
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <!-- Language switcher -->
                        <form id="selectLanguageForm" asp-controller="Language" asp-action="SetLanguage" method="post" class="d-flex align-items-center">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <select name="culture" onchange="this.form.submit()" class="form-select form-select-sm border-0 bg-light rounded-pill px-3 py-1 fs-13 cursor-pointer">
                                <option value="vi-VN" selected="@(System.Globalization.CultureInfo.CurrentCulture.Name == "vi-VN")">Tiếng Việt</option>
                                <option value="en-US" selected="@(System.Globalization.CultureInfo.CurrentCulture.Name == "en-US")">English</option>
                            </select>
                        </form>

                        <!-- Shopping Cart Badge -->
                        <a href="/Cart" class="btn btn-light rounded-pill position-relative px-3 py-2 border-0 bg-light-hover">
                            <i class="fa-solid fa-shopping-basket text-dark"></i>
                            @if (cartCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white">
                                    @cartCount
                                </span>
                            }
                        </a>

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-5 min-vh-75">
        @if (TempData["SuccessMessage"] != null && Context.Request.Path != "/Cart" && Context.Request.Path != "/don-hang-cua-toi")
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null && Context.Request.Path != "/Cart")
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-white py-4 mt-5 text-muted">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    &copy; 2026 - HUTECH Canteen Hub. Tất cả các quyền được bảo lưu.
                </div>
                <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                    <a href="#" class="text-decoration-none text-muted me-3">Chính sách bảo mật</a>
                    <a href="#" class="text-decoration-none text-muted">Điều khoản sử dụng</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/autocomplete.js" asp-append-version="true"></script>
    @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Admin") && !User.IsInRole("Employee"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
        <script>
            (function () {
                const dot = document.getElementById("publicChatDot");
                if (!dot || window.location.pathname.toLowerCase().startsWith("/chat")) return;
                const connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").withAutomaticReconnect().build();
                const showDot = () => dot.classList.remove("d-none");
                connection.on("GeneralMessageNotification", showDot);
                connection.on("PrivateMessageNotification", showDot);
                connection.on("SupportMessageNotification", showDot);
                connection.on("PrivateRequestNotification", showDot);
                connection.on("AccountAccessRevoked", data => {
                    alert(data?.message || "Tài khoản của bạn đã bị khóa.");
                    window.location.replace("/Identity/Account/Lockout");
                });
                connection.start().catch(() => {});
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
