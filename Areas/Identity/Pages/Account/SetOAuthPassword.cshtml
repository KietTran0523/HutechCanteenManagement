@page
@model SetOAuthPasswordModel
@{
    ViewData["Title"] = "Tạo mật khẩu";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="card-header text-white text-center py-4 border-0 oauth-password-header">
                <i class="fa-solid fa-shield-halved display-4 mb-2"></i>
                <h3 class="mb-1 fw-bold">Tạo mật khẩu</h3>
                <p class="mb-0 opacity-75 fs-14">Hoàn tất bước cuối để bảo vệ tài khoản</p>
            </div>
            <div class="card-body p-4 p-md-5 bg-white">
                <div class="alert alert-primary border-0 rounded-3 fs-14 mb-4">
                    <i class="fa-brands fa-google me-2"></i>
                    Google đã xác minh <strong>@Model.Input?.Email</strong>. Mật khẩu này giúp bạn đăng nhập khi không dùng Google.
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    <input asp-for="Input.Email" type="hidden" />
                    <input asp-for="Input.Code" type="hidden" />
                    <input asp-for="Input.ReturnUrl" type="hidden" />

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="new-password" placeholder="Mật khẩu" autofocus />
                        <label asp-for="Input.Password" class="px-4 text-muted"><i class="fa-solid fa-key me-2"></i>Mật khẩu</label>
                        <span asp-validation-for="Input.Password" class="text-danger fs-14 px-3"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill px-4" autocomplete="new-password" placeholder="Xác nhận mật khẩu" />
                        <label asp-for="Input.ConfirmPassword" class="px-4 text-muted"><i class="fa-solid fa-check-double me-2"></i>Xác nhận mật khẩu</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger fs-14 px-3"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm oauth-password-submit">
                        <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>Tạo mật khẩu và đăng nhập
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .oauth-password-header, .oauth-password-submit {
        background: linear-gradient(135deg, #1e40af 0%, #2563eb 55%, #0ea5e9 100%);
        border: 0;
    }
    .oauth-password-submit:hover { filter: brightness(.96); }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
