@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="card-header bg-success text-white text-center py-4 border-0" style="background: linear-gradient(135deg, #047857 0%, #10b981 100%);">
                <i class="fa-solid fa-lock-open display-4 mb-2"></i>
                <h3 class="mb-0 fw-bold">Đặt lại mật khẩu</h3>
            </div>
            <div class="card-body p-4 p-md-5 bg-white">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    <input asp-for="Input.Code" type="hidden" />
                    <input asp-for="Input.Email" type="hidden" />

                    <p class="text-muted mb-4">
                        Email xác nhận: <strong>@Model.Input?.Email</strong>
                    </p>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="new-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="px-4 text-muted"><i class="fa-solid fa-key me-2"></i>Mật khẩu mới</label>
                        <span asp-validation-for="Input.Password" class="text-danger fs-14 px-3"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill px-4" autocomplete="new-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.ConfirmPassword" class="px-4 text-muted"><i class="fa-solid fa-check-double me-2"></i>Xác nhận mật khẩu mới</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger fs-14 px-3"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100 rounded-pill py-3 fw-bold shadow-sm" style="background: linear-gradient(135deg, #047857 0%, #10b981 100%); border: none;">
                        <i class="fa-solid fa-floppy-disk me-2"></i> Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
