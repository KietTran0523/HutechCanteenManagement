@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="card-header bg-success text-white text-center py-4 border-0" style="background: linear-gradient(135deg, #047857 0%, #10b981 100%);">
                <i class="fa-solid fa-key display-4 mb-2"></i>
                <h3 class="mb-0 fw-bold">Quên mật khẩu</h3>
                <p class="mb-0 opacity-75 fs-14">Nhập email để nhận liên kết đặt lại mật khẩu</p>
            </div>
            <div class="card-body p-4 p-md-5 bg-white">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control rounded-pill px-4" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="px-4 text-muted"><i class="fa-solid fa-envelope me-2"></i>Email của bạn</label>
                        <span asp-validation-for="Input.Email" class="text-danger fs-14 px-3"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100 rounded-pill py-3 fw-bold shadow-sm" style="background: linear-gradient(135deg, #047857 0%, #10b981 100%); border: none;">
                        <i class="fa-solid fa-paper-plane me-2"></i> Gửi email đặt lại mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
