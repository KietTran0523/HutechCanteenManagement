@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h4 class="fw-bold mb-4 text-dark">@ViewData["Title"]</h4>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8">
        <form id="change-password-form" method="post" class="bg-light p-4 rounded-4 border">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <p class="text-muted mb-4">
                Nhập mật khẩu cũ để hệ thống gửi email xác nhận. Sau khi bấm link trong email, bạn sẽ nhập mật khẩu mới ở trang đặt lại mật khẩu.
            </p>

            <div class="form-floating mb-4">
                <input asp-for="Input.OldPassword" class="form-control rounded-pill px-4 bg-white" autocomplete="current-password" aria-required="true" placeholder="Nhập mật khẩu cũ" />
                <label asp-for="Input.OldPassword" class="px-4 text-muted"><i class="fa-solid fa-lock-open me-2"></i>Mật khẩu cũ</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger px-3 fs-14"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); border: none;">
                <i class="fa-solid fa-envelope me-2"></i> Gửi email xác nhận đổi mật khẩu
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
