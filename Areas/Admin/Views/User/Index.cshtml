@model IEnumerable<QuanLyCanTeenHutech.Areas.Admin.Controllers.UserRolesViewModel>
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold text-dark m-0"><i class="fa-solid fa-users-gear text-primary me-2"></i> @ViewData["Title"]</h4>
                <p class="text-muted fs-14 mt-1 mb-0">Quản lý phân quyền và xóa tài khoản người dùng trong hệ thống.</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3 px-4 text-secondary font-weight-500 border-0" style="width: 50px;">#</th>
                            <th class="py-3 px-4 text-secondary font-weight-500 border-0">Người dùng</th>
                            <th class="py-3 px-4 text-secondary font-weight-500 border-0">Vai trò / Quyền</th>
                            <th class="py-3 px-4 text-secondary font-weight-500 border-0 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int index = 1; }
                        @foreach (var user in Model)
                        {
                            <tr class="border-bottom">
                                <td class="px-4 text-muted">@index</td>
                                <td class="px-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 45px; height: 45px; font-size: 18px;">
                                            @user.UserName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <h6 class="fw-bold text-dark mb-0">@user.UserName</h6>
                                            <span class="text-muted fs-13"><i class="fa-solid fa-envelope me-1"></i> @user.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4">
                                    @if (!user.Roles.Any())
                                    {
                                        <span class="badge bg-light text-muted border px-2 py-1 rounded-pill fw-normal fs-12">Chưa phân quyền</span>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var role in user.Roles)
                                            {
                                                string badgeClass = "bg-secondary bg-opacity-10 text-secondary border-secondary";
                                                string icon = "fa-user";
                                                
                                                if (role == "Admin") {
                                                    badgeClass = "bg-danger bg-opacity-10 text-danger border-danger";
                                                    icon = "fa-user-shield";
                                                }
                                                else if (role == "Employee") {
                                                    badgeClass = "bg-info bg-opacity-10 text-info border-info";
                                                    icon = "fa-user-tie";
                                                }
                                                else if (role == "Customer") {
                                                    badgeClass = "bg-success bg-opacity-10 text-success border-success";
                                                    icon = "fa-user";
                                                }
                                                
                                                <span class="badge border px-2 py-1 rounded-pill fw-normal fs-12 @badgeClass">
                                                    <i class="fa-solid @icon me-1"></i> @role
                                                </span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="px-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/Admin/User/EditRoles/@user.UserId" class="btn btn-sm btn-light border text-primary rounded-pill px-3 shadow-sm hover-elevate">
                                            <i class="fa-solid fa-pen-to-square me-1"></i> Phân quyền
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm hover-elevate" onclick="confirmDelete('@user.UserId', '@user.UserName')">
                                            <i class="fa-solid fa-trash-can me-1"></i> Xóa
                                        </button>
                                    </div>
                                    
                                    <!-- Hidden Delete Form -->
                                    <form id="delete-form-@user.UserId" asp-action="Delete" method="post" class="d-none">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.UserId" />
                                    </form>
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-elevate {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-elevate:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 6px rgba(0,0,0,0.1) !important;
    }
</style>

<script>
    function confirmDelete(userId, userName) {
        if (confirm(`Bạn có chắc chắn muốn xóa tài khoản ${userName} không? Hành động này không thể hoàn tác!`)) {
            document.getElementById('delete-form-' + userId).submit();
        }
    }
</script>
