@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "Phân quyền người dùng";
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
    var userRoles = ViewBag.UserRoles as IList<string> ?? new List<string>();
    var currentRole = userRoles.FirstOrDefault() ?? "Customer";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-premium">
            <div class="card-title-premium text-dark">
                <span>Cập nhật vai trò tài khoản</span>
                <a href="/Admin/User" class="btn btn-sm btn-light border"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
            </div>

            <div class="mb-4">
                <table class="table table-bordered bg-light">
                    <tr>
                        <th class="w-40">Tên tài khoản</th>
                        <td>@Model.UserName</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>@Model.Email</td>
                    </tr>
                </table>
            </div>

            <form asp-action="EditRoles" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label font-weight-500">Chọn vai trò mới</label>
                    <select name="selectedRole" class="form-select">
                        @foreach (var role in allRoles)
                        {
                            <option value="@role" selected="@(role == currentRole)">
                                @if (role == "Admin") { <text>Quản trị viên (Admin)</text> }
                                else if (role == "Employee") { <text>Nhân viên căng tin (Employee)</text> }
                                else { <text>Khách hàng / Sinh viên (Customer)</text> }
                            </option>
                        }
                    </select>
                </div>

                <div class="mt-4 pt-3 border-top d-flex gap-2">
                    <button type="submit" class="btn btn-teal text-white btn-premium btn-premium-primary"><i class="fa-solid fa-save me-1"></i> Cập nhật quyền</button>
                    <a href="/Admin/User" class="btn btn-light border btn-premium">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>
