@model QuanLyCanTeenHutech.Models.Category
@{
    ViewData["Title"] = "Xác nhận xóa danh mục";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-premium border-danger">
            <div class="card-title-premium text-danger">
                <span><i class="fa-solid fa-triangle-exclamation"></i> Cảnh báo xóa danh mục</span>
                <a href="/Admin/Category" class="btn btn-sm btn-light border text-dark"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
            </div>

            <div class="alert alert-warning border-0 shadow-sm mb-4">
                Bạn có chắc chắn muốn xóa danh mục <strong>@Model.Name</strong>?
                <br />
                <span class="fs-7 text-muted mt-1 d-block"><i class="fa-solid fa-info-circle"></i> Sản phẩm trong danh mục này sẽ hiển thị ở dạng "Không có danh mục". Đơn hàng đã mua trước đó sẽ không bị ảnh hưởng.</span>
            </div>

            <table class="table table-bordered mb-4">
                <tr>
                    <th class="w-30 bg-light">Tên danh mục</th>
                    <td>@Model.Name</td>
                </tr>
                <tr>
                    <th class="bg-light">Mô tả</th>
                    <td>@(string.IsNullOrEmpty(Model.Description) ? "(Không có)" : Model.Description)</td>
                </tr>
            </table>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-premium btn-premium-danger"><i class="fa-solid fa-trash-can me-1"></i> Đồng ý xóa</button>
                    <a href="/Admin/Category" class="btn btn-light border btn-premium">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>
