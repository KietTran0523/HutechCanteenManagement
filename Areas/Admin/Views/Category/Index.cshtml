@model IEnumerable<QuanLyCanTeenHutech.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="card-premium">
    <div class="card-title-premium text-dark">
        <span>Danh mục thực đơn</span>
        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Category/Create" class="btn btn-sm btn-teal text-white btn-premium btn-premium-primary"><i class="fa-solid fa-plus me-1"></i> Thêm danh mục</a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã</th>
                    <th>Tên danh mục</th>
                    <th>Slug</th>
                    <th>Mô tả</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-end">Hành động</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@(User.IsInRole("Admin") ? 5 : 4)" class="text-center text-muted py-4">Chưa có danh mục nào. Hãy bấm "Thêm danh mục" để bắt đầu.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.Id</strong></td>
                            <td><strong class="text-dark">@item.Name</strong></td>
                            <td><code class="text-secondary">@item.Slug</code></td>
                            <td class="text-muted">@(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)</td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a href="/Admin/Category/Edit/@item.Id" class="btn btn-sm btn-light border me-1"><i class="fa-solid fa-edit text-primary"></i> Sửa</a>
                                    <a href="/Admin/Category/Delete/@item.Id" class="btn btn-sm btn-light border"><i class="fa-solid fa-trash-can text-danger"></i> Xóa</a>
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
