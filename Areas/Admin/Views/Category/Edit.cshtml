@model QuanLyCanTeenHutech.Models.Category
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card-premium">
            <div class="card-title-premium text-dark">
                <span>Cập nhật danh mục: @Model.Name</span>
                <a href="/Admin/Category" class="btn btn-sm btn-light border"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Slug" />
                <input type="hidden" asp-for="IsDeleted" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label font-weight-500"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="NameEn" class="form-label font-weight-500"></label>
                        <input asp-for="NameEn" class="form-control" />
                        <span asp-validation-for="NameEn" class="text-danger fs-7"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Description" class="form-label font-weight-500"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DescriptionEn" class="form-label font-weight-500"></label>
                        <textarea asp-for="DescriptionEn" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="DescriptionEn" class="text-danger fs-7"></span>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex gap-2">
                    <button type="submit" class="btn btn-teal text-white btn-premium btn-premium-primary"><i class="fa-solid fa-save me-1"></i> Lưu thay đổi</button>
                    <a href="/Admin/Category" class="btn btn-light border btn-premium">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
