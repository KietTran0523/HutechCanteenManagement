@model QuanLyCanTeenHutech.Models.Order
@{
    ViewData["Title"] = $"Chỉnh sửa đơn hàng #{Model.Id}";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card-premium">
            <div class="card-title-premium text-dark border-bottom pb-2">
                <span><i class="fa-solid fa-pen-to-square text-warning me-2"></i>Chỉnh sửa thông tin đơn hàng</span>
            </div>

            <div class="card-body mt-3">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="OrderDate" />
                    <input type="hidden" asp-for="TotalAmount" />
                    <input type="hidden" asp-for="CustomerId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="FullName" class="form-control rounded-pill bg-light border-0" placeholder="Họ tên" />
                                <label asp-for="FullName" class="text-muted"><i class="fa-solid fa-user me-2"></i>Họ tên khách hàng</label>
                                <span asp-validation-for="FullName" class="text-danger fs-14"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="PhoneNumber" class="form-control rounded-pill bg-light border-0" placeholder="Số điện thoại" />
                                <label asp-for="PhoneNumber" class="text-muted"><i class="fa-solid fa-phone me-2"></i>Số điện thoại</label>
                                <span asp-validation-for="PhoneNumber" class="text-danger fs-14"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="ShippingAddress" class="form-control rounded-pill bg-light border-0" placeholder="Vị trí nhận" />
                        <label asp-for="ShippingAddress" class="text-muted"><i class="fa-solid fa-location-dot me-2"></i>Vị trí nhận hàng (bàn/khu vực)</label>
                        <span asp-validation-for="ShippingAddress" class="text-danger fs-14"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <select asp-for="Status" class="form-select rounded-pill bg-light border-0">
                            <option value="Pending">Chờ xử lý (Pending)</option>
                            <option value="Confirmed">Xác nhận (Confirmed)</option>
                            <option value="Completed">Hoàn thành (Completed)</option>
                            <option value="Cancelled">Hủy đơn (Cancelled)</option>
                        </select>
                        <label asp-for="Status" class="text-muted"><i class="fa-solid fa-spinner me-2"></i>Trạng thái đơn hàng</label>
                        <span asp-validation-for="Status" class="text-danger fs-14"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Notes" class="form-control rounded-4 bg-light border-0" style="height: 100px" placeholder="Ghi chú"></textarea>
                        <label asp-for="Notes" class="text-muted"><i class="fa-regular fa-comment-dots me-2"></i>Ghi chú</label>
                        <span asp-validation-for="Notes" class="text-danger fs-14"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="/Admin/Order/Details/@Model.Id" class="btn btn-light rounded-pill px-4 border"><i class="fa-solid fa-arrow-left me-1"></i> Trở lại</a>
                        <button type="submit" class="btn btn-warning text-dark fw-bold rounded-pill px-5 shadow-sm">
                            <i class="fa-solid fa-floppy-disk me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
