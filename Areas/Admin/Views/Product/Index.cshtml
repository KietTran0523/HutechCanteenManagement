@model IEnumerable<QuanLyCanTeenHutech.Models.Product>
@{
    ViewData["Title"] = "Quản lý món ăn";
}

<div class="card-premium">
    <div class="card-title-premium text-dark">
        <span>Danh sách món ăn & nước uống</span>
        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Product/Create" class="btn btn-sm btn-teal text-white btn-premium btn-premium-primary"><i class="fa-solid fa-plus me-1"></i> Thêm món mới</a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã</th>
                    <th>Tên món ăn</th>
                    <th>Giá bán</th>
                    <th>Danh mục</th>
                    <th>Slug</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-end">Hành động</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@(User.IsInRole("Admin") ? 6 : 5)" class="text-center text-muted py-4">Chưa có món ăn nào. Bấm "Thêm món mới" để bắt đầu.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.Id</strong></td>
                            <td>
                                <strong class="text-dark">@item.Name</strong>
                            </td>
                            <td><strong class="text-teal text-success">@item.Price.ToString("#,##0") đ</strong></td>
                            <td>
                                @if (item.Category != null)
                                {
                                    <span class="badge bg-secondary">@item.Category.Name</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted">Không có danh mục</span>
                                }
                            </td>
                            <td><code class="text-secondary">@item.Slug</code></td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a href="/Admin/Product/Edit/@item.Id" class="btn btn-sm btn-light border me-1"><i class="fa-solid fa-edit text-primary"></i> Sửa</a>
                                    <a href="/Admin/Product/Delete/@item.Id" class="btn btn-sm btn-light border"><i class="fa-solid fa-trash-can text-danger"></i> Xóa</a>
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
