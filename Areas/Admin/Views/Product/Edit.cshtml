@model QuanLyCanTeenHutech.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa món ăn";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card-premium">
            <div class="card-title-premium text-dark">
                <span>Cập nhật món ăn: @Model.Name</span>
                <a href="/Admin/Product" class="btn btn-sm btn-light border"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Slug" />
                <input type="hidden" asp-for="IsDeleted" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Name" class="form-label font-weight-500"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger fs-7"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="NameEn" class="form-label font-weight-500"></label>
                        <input asp-for="NameEn" class="form-control" />
                        <span asp-validation-for="NameEn" class="text-danger fs-7"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Price" class="form-label font-weight-500"></label>
                        <div class="input-group">
                            <input asp-for="Price" type="number" class="form-control" />
                            <span class="input-group-text">VND</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger fs-7"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="CategoryId" class="form-label font-weight-500"></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Chọn danh mục thực đơn --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger fs-7"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Description" class="form-label font-weight-500"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger fs-7"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DescriptionEn" class="form-label font-weight-500"></label>
                        <textarea asp-for="DescriptionEn" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="DescriptionEn" class="text-danger fs-7"></span>
                    </div>
                </div>

                <!-- Existing Media Files -->
                <div class="mb-4">
                    <label class="form-label font-weight-500"><i class="fa-solid fa-photo-film text-secondary"></i> Các ảnh & video hiện tại</label>
                    
                    @if (Model.ProductGalleries == null || !Model.ProductGalleries.Any())
                    {
                        <p class="text-muted fs-7 bg-light p-3 rounded"><i class="fa-solid fa-circle-info"></i> Chưa có hình ảnh hoặc video minh họa cho món ăn này.</p>
                    }
                    else
                    {
                        <div class="gallery-grid">
                            @foreach (var media in Model.ProductGalleries)
                            {
                                var divId = "media-item-" + media.Id;
                                <div class="gallery-item" id="@divId">
                                    @if (media.MediaType == "video")
                                    {
                                        <video src="@media.FilePath" controls muted preload="metadata"></video>
                                        <span class="media-type-badge">Video</span>
                                    }
                                    else
                                    {
                                        <img src="@media.FilePath" alt="Ảnh món ăn" />
                                        <span class="media-type-badge">Ảnh</span>
                                    }
                                    <button type="button" class="remove-media-btn" onclick="removeMedia(@media.Id, '@divId')" title="Xóa tệp này">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Media Uploads (Images & Videos) -->
                <div class="mb-4">
                    <label class="form-label font-weight-500"><i class="fa-solid fa-plus-circle text-secondary"></i> Tải lên thêm ảnh / video</label>
                    <input type="file" name="mediaFiles" class="form-control" multiple accept="image/*,video/*" />
                    <small class="text-muted mt-1 d-block"><i class="fa-solid fa-circle-info"></i> Hệ thống hỗ trợ ảnh (jpg, png, gif) và video (mp4, webm, mov).</small>
                </div>

                <div class="mt-4 pt-3 border-top d-flex gap-2">
                    <button type="submit" class="btn btn-teal text-white btn-premium btn-premium-primary"><i class="fa-solid fa-save me-1"></i> Lưu thay đổi</button>
                    <a href="/Admin/Product" class="btn btn-light border btn-premium">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function removeMedia(mediaId, elementId) {
            if (confirm("Bạn có chắc chắn muốn xóa tệp phương tiện này không? Thao tác này không thể hoàn tác.")) {
                fetch('/Admin/Product/RemoveMedia?mediaId=' + mediaId, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(response => {
                    if (response.ok) {
                        return response.json();
                    }
                    throw new Error("Lỗi khi gửi yêu cầu.");
                })
                .then(data => {
                    if (data.success) {
                        const elem = document.getElementById(elementId);
                        if (elem) {
                            elem.style.transform = 'scale(0.8)';
                            elem.style.opacity = '0';
                            setTimeout(() => elem.remove(), 250);
                        }
                    } else {
                        alert("Xóa tệp phương tiện thất bại!");
                    }
                })
                .catch(error => {
                    console.error(error);
                    alert("Lỗi kết nối tới máy chủ.");
                });
            }
        }
    </script>
}
